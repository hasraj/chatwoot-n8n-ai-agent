                                         "jsCode":  "const item = $input.first().json;\nconst body = item.body ?? item;\n\nconst normalizeBaseUrl = (value, fallback) =\u003e {\n  const finalValue = String(value || fallback || \u0027\u0027).trim();\n  return finalValue.replace(/\\/$/, \u0027\u0027);\n};\n\nconst content = String(body.content ?? \u0027\u0027).trim();\nconst senderType = body.sender?.type ?? body.sender_type ?? body.conversation?.meta?.sender?.type ?? \u0027\u0027;\nconst messageType = body.message_type;\nconst isIncoming = messageType === \u0027incoming\u0027 || messageType === 0 || messageType === \u00270\u0027;\nconst isPrivate = Boolean(body.private);\nconst shouldInspect =\n  body.event === \u0027message_created\u0027 \u0026\u0026\n  isIncoming \u0026\u0026\n  senderType === \u0027contact\u0027 \u0026\u0026\n  !isPrivate \u0026\u0026\n  content.length \u003e 0;\n\nconst orderMatch =\n  content.match(/(?:order\\s*#?\\s*|#)(\\d{4,})\\b/i) ||\n  content.match(/\\b(\\d{5,})\\b/);\n\nreturn {\n  route: shouldInspect ? \u0027process\u0027 : \u0027ignore\u0027,\n  event: body.event ?? \u0027\u0027,\n  isIncoming,\n  senderType,\n  isPrivate,\n  content_length: content.length,\n  messageId: body.id ?? null,\n  conversationId: body.conversation?.id ?? body.conversation_id ?? null,\n  accountId: body.account?.id ?? body.account_id ?? null,\n  inboxId: body.inbox?.id ?? body.inbox_id ?? body.conversation?.inbox_id ?? null,\n  content,\n  senderType,\n  messageType,\n  detectedOrderId: orderMatch ? orderMatch[1] : \u0027\u0027,\n  config: {\n    chatwootBaseUrl: normalizeBaseUrl(\u0027\u0027, \u0027https://sac.famivita.com\u0027),\n    wooBaseUrl: normalizeBaseUrl(\u0027\u0027, \u0027https://famivita.com.br\u0027),\n    openAiModel: \u0027gpt-4.1-mini\u0027,\n    processingMode: \u0027live\u0027,\n    allowedPhoneNumbers: [],\n    allowedLabels: [],\n    allowedInboxIds: [],\n    maxConversationMessages: 8,\n    supportEmail: \u0027support@famivita.com\u0027,